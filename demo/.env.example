# Copy to .env and fill in, then either `export $(cat .env | xargs)` or run the
# demo with `node --env-file=.env dist/index.js <scenario>`.

# Required: your Anthropic API key (the demo makes real API calls).
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model (default: claude-haiku-4-5-20251001).
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: capture prompt/response content as span attributes (default: off).
# AGENT_OTEL_CAPTURE_CONTENT=true

# Optional: point at a non-default OTLP/HTTP traces endpoint.
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces

# Optional: also print spans to stdout (useful without Jaeger).
# OTEL_CONSOLE=true
